    # === ОБЩИЕ CALLBACK ===

    @router.callback_query(F.data == "cancel")
    async def cb_cancel(callback: types.CallbackQuery, state: FSMContext):
        await state.clear()
        await callback.message.edit_text("Отменено.", reply_markup=build_main_menu(bot_id))
        await callback.answer()

    @router.callback_query(F.data == "user_mode")
    async def cb_user(callback: types.CallbackQuery):
        await callback.message.edit_text("Меню:", reply_markup=build_main_menu(bot_id))
        await callback.answer()

    @router.callback_query(F.data == "admin_mode")
    async def cb_admin(callback: types.CallbackQuery):
        if is_admin(callback.from_user.id, bot_id):
            await callback.message.edit_text("Админ-панель:", reply_markup=build_admin_menu(callback.from_user.id, bot_id))
        else:
            await callback.answer("Нет доступа", show_alert=True)
        await callback.answer()

    @router.callback_query(F.data == "back_main")
    async def cb_back(callback: types.CallbackQuery):
        await callback.message.edit_text("Меню:", reply_markup=build_main_menu(bot_id))
        await callback.answer()

    # === БАЛАНС (ВСЕ ВАЛЮТЫ) ===

    @router.callback_query(F.data == "balance")
    async def cb_balance(callback: types.CallbackQuery):
        cfg = storage.bots.get(bot_id)
        user = storage.users.get(callback.from_user.id)
        if not user:
            await callback.answer("Не зарегистрированы", show_alert=True)
            return

        status = ""
        if user.is_frozen.get(bot_id, False):
            status += "❄️ Счёт заморожен\n"
        if user.is_blocked.get(bot_id, False):
            status += "🚫 Заблокирован для тейков\n"

        main_bal = get_balance(callback.from_user.id, bot_id)
        main_bal_str = "∞" if main_bal == float('inf') else f"{main_bal:.0f}"

        text = f"{status}💳 Балансы:\n\n"
        text += f"▸ {cfg.currency_name} {cfg.currency_emoji}: {main_bal_str} (текущий)\n"

        for other_id, other_cfg in storage.bots.items():
            if other_id != bot_id:
                other_bal = get_balance(callback.from_user.id, other_id)
                if other_bal > 0 or other_bal == float('inf'):
                    other_str = "∞" if other_bal == float('inf') else f"{other_bal:.0f}"
                    text += f"▸ {other_cfg.currency_name} {other_cfg.currency_emoji}: {other_str}\n"

        can_take, cooldown_msg = can_send_take(callback.from_user.id, bot_id)
        text += f"\n📝 Тейки: {'✅ доступно' if can_take else f'⏳ {cooldown_msg}'}"

        await callback.message.edit_text(text, reply_markup=build_main_menu(bot_id))
        await callback.answer()

    # === ТОП ===

    @router.callback_query(F.data == "top")
    async def cb_top(callback: types.CallbackQuery):
        cfg = storage.bots.get(bot_id)
        users_list = []
        for uid, user in storage.users.items():
            if user.show_in_top.get(bot_id, True) and not user.is_owner.get(bot_id, False):
                bal = user.balances.get(bot_id, 0)
                if bal != float('inf') and bal != "inf":
                    users_list.append((user.username, float(bal)))
        users_list.sort(key=lambda x: x[1], reverse=True)
        text = f"🏆 Топ {cfg.currency_name}:\n\n"
        for i, (username, bal) in enumerate(users_list[:10], 1):
            text += f"{i}. @{username} — {bal:.0f} {cfg.currency_emoji}\n"
        if not users_list:
            text += "Пока пусто"
        await callback.message.edit_text(text, reply_markup=build_main_menu(bot_id))
        await callback.answer()

    # === ПЕРЕВОДЫ ===

    @router.callback_query(F.data == "transfer")
    async def cb_transfer(callback: types.CallbackQuery, state: FSMContext):
        user = storage.users.get(callback.from_user.id)
        if user and user.is_frozen.get(bot_id, False):
            await callback.answer("❄️ Счёт заморожен!", show_alert=True)
            return
        await callback.message.edit_text("Введите username или ID получателя:", reply_markup=build_cancel_keyboard())
        await state.set_state(TransferStates.WaitingReceiver)
        await callback.answer()

    @router.message(TransferStates.WaitingReceiver)
    async def transfer_recv(message: types.Message, state: FSMContext):
        receiver_id = find_user_by_input(message.text)
        if not receiver_id:
            await message.answer("Не найден. Попробуйте ещё:", reply_markup=build_cancel_keyboard())
            return
        if receiver_id == message.from_user.id:
            await message.answer("Нельзя себе.", reply_markup=build_cancel_keyboard())
            return
        recv = storage.users.get(receiver_id)
        if recv and recv.is_frozen.get(bot_id, False):
            await message.answer("❄️ Счёт получателя заморожен.", reply_markup=build_cancel_keyboard())
            return
        await state.update_data(receiver_id=receiver_id)
        await message.answer("Сумма (сообщение на новой строке):\n\nПример:\n100\nСпасибо!", reply_markup=build_cancel_keyboard())
        await state.set_state(TransferStates.WaitingAmountAndMessage)

    @router.message(TransferStates.WaitingAmountAndMessage)
    async def transfer_amt(message: types.Message, state: FSMContext):
        lines = message.text.strip().split('\n', 1)
        try:
            amount = float(lines[0])
            if amount <= 0:
                raise ValueError
        except ValueError:
            await message.answer("Неверная сумма.", reply_markup=build_cancel_keyboard())
            return
        msg = lines[1].strip() if len(lines) > 1 else ""
        data = await state.get_data()
        receiver_id = data['receiver_id']
        cfg = storage.bots.get(bot_id)
        ok, err = transfer_balance(message.from_user.id, receiver_id, bot_id, amount)
        if ok:
            recv = storage.users.get(receiver_id)
            await message.answer(f"✅ Переведено {amount:.0f} {cfg.currency_emoji} → @{recv.username}", reply_markup=build_main_menu(bot_id))
            notif = f"💰 Получено {amount:.0f} {cfg.currency_emoji} от @{storage.users[message.from_user.id].username}"
            if msg:
                notif += f"\n💬 {msg}"
            try:
                await bot_instance.send_message(receiver_id, notif)
            except Exception:
                pass
        else:
            await message.answer(f"❌ {err}", reply_markup=build_main_menu(bot_id))
        await state.clear()

    # === КУРСЫ / КОНВЕРТАЦИЯ ===

    @router.callback_query(F.data == "rates")
    async def cb_rates(callback: types.CallbackQuery):
        text = "📊 Курсы валют:\n\n"
        for bid, cfg in storage.bots.items():
            text += f"{cfg.currency_name} {cfg.currency_emoji}: {get_exchange_rate(bid):.2f}\n"
