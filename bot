# ====================== BOT CONNECTION ======================
def create_connection_handlers(bot_instance: Bot, dp: Dispatcher):
    router = Router()

    @router.callback_query(F.data == "connect_bot")
    async def cb_connect(callback: types.CallbackQuery, state: FSMContext):
        await callback.message.edit_text("🤖 Отправьте ссылку на ваш канал:", reply_markup=build_cancel_kb())
        await state.set_state(ConnectBotStates.WaitingChannelUrl)
        await callback.answer()

    @router.message(ConnectBotStates.WaitingChannelUrl)
    async def connect_channel(message: types.Message, state: FSMContext):
        request_id = str(uuid.uuid4())[:8]
        request = PendingBotRequest(
            request_id=request_id,
            user_id=message.from_user.id,
            channel_url=message.text.strip()
        )
        storage.pending_requests[request_id] = request
        storage.save()

        user = storage.users.get(message.from_user.id)
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [
                InlineKeyboardButton(text="✅ Одобрить", callback_data=f"req_ok_{request_id}"),
                InlineKeyboardButton(text="❌ Отклонить", callback_data=f"req_no_{request_id}")
            ]
        ])
        try:
            await bot_instance.send_message(
                MAIN_ADMIN_ID,
                f"📝 Заявка на подключение\nОт: @{user.username if user else '?'}\nКанал: {message.text}",
                reply_markup=kb
            )
        except: pass
        await message.answer("✅ Заявка отправлена!", reply_markup=build_main_menu("main"))
        await state.clear()

    @router.callback_query(F.data.startswith("req_ok_"))
    async def req_approve(callback: types.CallbackQuery):
        if callback.from_user.id != MAIN_ADMIN_ID:
            await callback.answer("Нет доступа", show_alert=True)
            return
        rid = callback.data[7:]
        req = storage.pending_requests.get(rid)
        if not req:
            await callback.answer("Не найдено", show_alert=True)
            return

        kb = InlineKeyboardMarkup(inline_keyboard=[
            [
                InlineKeyboardButton(text="✅ Да", callback_data=f"req_confirm_{rid}"),
                InlineKeyboardButton(text="❌ Нет", callback_data=f"req_back_{rid}")
            ]
        ])
        await callback.message.edit_text("Вы уверены?", reply_markup=kb)
        await callback.answer()

    @router.callback_query(F.data.startswith("req_back_"))
    async def req_back(callback: types.CallbackQuery):
        rid = callback.data[9:]
        req = storage.pending_requests.get(rid)
        if req:
            user = storage.users.get(req.user_id)
            kb = InlineKeyboardMarkup(inline_keyboard=[
                [
                    InlineKeyboardButton(text="✅ Одобрить", callback_data=f"req_ok_{rid}"),
                    InlineKeyboardButton(text="❌ Отклонить", callback_data=f"req_no_{rid}")
                ]
            ])
            await callback.message.edit_text(
                f"📝 Заявка\nОт: @{user.username if user else '?'}\nКанал: {req.channel_url}",
                reply_markup=kb
            )
        await callback.answer()

    @router.callback_query(F.data.startswith("req_confirm_"))
    async def req_confirm(callback: types.CallbackQuery):
        if callback.from_user.id != MAIN_ADMIN_ID:
            await callback.answer("Нет доступа", show_alert=True)
            return
        rid = callback.data[12:]
        req = storage.pending_requests.get(rid)
        if not req:
            await callback.answer("Не найдено", show_alert=True)
            return

        req.status = "token_wait"
        storage.waiting_for_token[req.user_id] = rid
        storage.save()

        try:
            await bot_instance.send_message(
                req.user_id,
                "✅ Заявка одобрена!\n\nОтправьте токен бота от @BotFather:"
            )
            await callback.message.edit_text("⏳ Ожидаем токен...")
        except Exception as e:
            await callback.message.edit_text(f"❌ Ошибка: {e}")
        await callback.answer()

    @router.callback_query(F.data.startswith("req_no_"))
    async def req_reject(callback: types.CallbackQuery):
        if callback.from_user.id != MAIN_ADMIN_ID:
            await callback.answer("Нет доступа", show_alert=True)
            return
        rid = callback.data[7:]
        req = storage.pending_requests.get(rid)
        if req:
            try:
                await bot_instance.send_message(req.user_id, "❌ Заявка отклонена")
            except: pass
            del storage.pending_requests[rid]
            storage.save()
        await callback.message.edit_text("❌ Отклонено")
        await callback.answer()

    @router.message(F.text.regexp(r'^\d{8,10}:[A-Za-z0-9_-]{35,}$'))
    async def receive_token(message: types.Message, state: FSMContext):
        uid = message.from_user.id
        if uid not in storage.waiting_for_token:
            return

        rid = storage.waiting_for_token[uid]
        req = storage.pending_requests.get(rid)
        if not req or req.status != "token_wait":
            del storage.waiting_for_token[uid]
            return

        token = message.text.strip()
        try:
            test_bot = Bot(token=token)
            info = await test_bot.get_me()
            await test_bot.session.close()

            req.token = token
            req.status = "configuring"
            del storage.waiting_for_token[uid]
            storage.save()

            await state.update_data(request_id=rid)
            await message.answer(f"✅ Бот @{info.username}\n\nНазвание валюты:")
            await state.set_state(ConnectBotStates.WaitingCurrencyName)

            try:
                await bot_instance.send_message(MAIN_ADMIN_ID, f"✅ Токен получен: @{info.username}")
            except: pass
        except Exception as e:
            await message.answer(f"❌ Неверный токен: {e}\nПопробуйте снова:")

    @router.message(ConnectBotStates.WaitingCurrencyName)
    async def currency_name(message: types.Message, state: FSMContext):
        data = await state.get_data()
        req = storage.pending_requests.get(data.get('request_id'))
        if req:
            req.currency_name = message.text.strip()
            storage.save()
        await message.answer("Эмодзи валюты (💎, 🪙, ⭐):")
        await state.set_state(ConnectBotStates.WaitingCurrencyEmoji)

    @router.message(ConnectBotStates.WaitingCurrencyEmoji)
    async def currency_emoji(message: types.Message, state: FSMContext):
        data = await state.get_data()
        req = storage.pending_requests.get(data.get('request_id'))
        if req:
            req.currency_emoji = message.text.strip()
            storage.save()
        await message.answer("Выберите модули:", reply_markup=build_modules_kb())
        await state.set_state(ConnectBotStates.WaitingModules)

    @router.callback_query(ConnectBotStates.WaitingModules, F.data.startswith("mod_"))
    async def select_modules(callback: types.CallbackQuery, state: FSMContext):
        mod = callback.data[4:]
        data = await state.get_data()
        req = storage.pending_requests.get(data.get('request_id'))
        if not req:
            await callback.answer("Ошибка", show_alert=True)
            return

        if mod == "takes":
            req.modules = ["takes"]
            storage.save()
            await callback.message.edit_text("Ссылка на канал для тейков (@channel):")
            await state.set_state(ConnectBotStates.WaitingTakesChannel)
        elif mod == "shop":
            req.modules = ["shop"]
            storage.save()
            await callback.message.edit_text("Ссылка на группу магазина (@group):")
            await state.set_state(ConnectBotStates.WaitingShopChannel)
        else:
            req.modules = ["takes", "shop"]
            storage.save()
            await callback.message.edit_text("Сначала канал для тейков (@channel):")
            await state.set_state(ConnectBotStates.WaitingTakesChannel)
        await callback.answer()

    @router.message(ConnectBotStates.WaitingTakesChannel)
    async def takes_channel(message: types.Message, state: FSMContext):
        data = await state.get_data()
        req = storage.pending_requests.get(data.get('request_id'))
        if not req:
            return

        channel = message.text.strip()
        if not channel.startswith("@"):
            channel = "@" + channel.replace("https://t.me/", "")
        req.takes_channel = channel
        storage.save()

        if "shop" in req.modules:
            await message.answer("Теперь группа магазина (@group):")
            await state.set_state(ConnectBotStates.WaitingShopChannel)
        else:
            await finish_setup(message, state, req, bot_instance)

    @router.message(ConnectBotStates.WaitingShopChannel)
    async def shop_channel(message: types.Message, state: FSMContext):
        data = await state.get_data()
        req = storage.pending_requests.get(data.get('request_id'))
        if not req:
            return

        channel = message.text.strip()
        if not channel.startswith("@"):
            channel = "@" + channel.replace("https://t.me/", "")
        req.shop_channel = channel
        storage.save()

        await finish_setup(message, state, req, bot_instance)

    async def finish_setup(message, state, req, main_bot):
        await message.answer("⏳ Запускаю бота...")

        try:
            bot_id = f"bot_{req.user_id}_{int(datetime.now().timestamp())}"

            config = BotConfig(
                bot_id=bot_id,
                token=req.token,
                currency_name=req.currency_name,
                currency_emoji=req.currency_emoji,
                channel_url=req.channel_url,
                takes_channel=req.takes_channel,
                shop_channel=req.shop_channel,
                modules=req.modules,
                owner_id=req.user_id,
                base_exchange_rate=0.5
            )

            storage.bots[bot_id] = config

            user = storage.users.get(req.user_id)
            if user:
                user.is_owner[bot_id] = True
                user.is_admin[bot_id] = True
                user.balances[bot_id] = float('inf')
                user.quiz_passed[bot_id] = False
                user.takes_timestamps[bot_id] = []
                user.show_in_top[bot_id] = True
                user.is_blocked[bot_id] = False
                user.is_frozen[bot_id] = False
                user.is_moderator[bot_id] = False

            storage.exchange_rates.rates[bot_id] = 0.5

            if req.request_id in storage.pending_requests:
                del storage.pending_requests[req.request_id]
            storage.save()

            new_bot = Bot(token=req.token)
            new_dp = Dispatcher(storage=MemoryStorage())
            create_bot_handlers(bot_id, new_bot, new_dp)

            storage.active_bots[bot_id] = new_bot
            storage.active_dispatchers[bot_id] = new_dp

            asyncio.create_task(new_dp.start_polling(new_bot))

            mods = ", ".join(req.modules)
            await message.answer(
                f"✅ Бот подключён!\n\n"
                f"💰 Валюта: {req.currency_name} {req.currency_emoji}\n"
                f"📦 Модули: {mods}\n\n"
                f"Вы — владелец с ∞ балансом.\nПерейдите в бота и /start",
                reply_markup=build_main_menu("main")
            )

            try:
                await main_bot.send_message(MAIN_ADMIN_ID, f"✅ Бот {bot_id} запущен!")
            except: pass

        except Exception as e:
            logger.error(f"Setup error: {e}")
            await message.answer(f"❌ Ошибка: {e}", reply_markup=build_main_menu("main"))

        await state.clear()

    dp.include_router(router)

# ====================== MAIN ======================
async def main():
    storage.load()

    main_bot = Bot(token=MAIN_BOT_TOKEN)
    main_dp = Dispatcher(storage=MemoryStorage())

    create_bot_handlers("main", main_bot, main_dp)
    create_connection_handlers(main_bot, main_dp)

    storage.active_bots["main"] = main_bot
    storage.active_dispatchers["main"] = main_dp

    for bot_id, config in storage.bots.items():
        if bot_id != "main":
            try:
                connected_bot = Bot(token=config.token)
                connected_dp = Dispatcher(storage=MemoryStorage())
                create_bot_handlers(bot_id, connected_bot, connected_dp)
                storage.active_bots[bot_id] = connected_bot
                storage.active_dispatchers[bot_id] = connected_dp
                asyncio.create_task(connected_dp.start_polling(connected_bot))
                logger.info(f"Started bot: {bot_id}")
            except Exception as e:
                logger.error(f"Error starting {bot_id}: {e}")

    logger.info("Starting main bot...")
    await main_dp.start_polling(main_bot)

if __name__ == "__main__":
    print("🚀 Запуск...")
    asyncio.run(main())
