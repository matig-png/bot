async def forward_take_to_channel(message: types.Message, user_id: int) -> Optional[types.Message]:
    try:
        sent_message = None
        
        if message.photo:
            raw_caption = message.caption or ""
            censored_caption, has_profanity = censor_profanity(raw_caption)
            sent_message = await bot.send_photo(
                TAKES_CHANNEL,
                photo=message.photo[-1].file_id,
                caption=censored_caption if has_profanity else raw_caption,
                parse_mode="HTML" if has_profanity else None,
            )

        elif message.video:
            raw_caption = message.caption or ""
            censored_caption, has_profanity = censor_profanity(raw_caption)
            sent_message = await bot.send_video(
                TAKES_CHANNEL,
                video=message.video.file_id,
                caption=censored_caption if has_profanity else raw_caption,
                parse_mode="HTML" if has_profanity else None,
            )

        elif message.document:
            raw_caption = message.caption or ""
            censored_caption, has_profanity = censor_profanity(raw_caption)
            sent_message = await bot.send_document(
                TAKES_CHANNEL,
                document=message.document.file_id,
                caption=censored_caption if has_profanity else raw_caption,
                parse_mode="HTML" if has_profanity else None,
            )

        elif message.animation:
            raw_caption = message.caption or ""
            censored_caption, has_profanity = censor_profanity(raw_caption)
            sent_message = await bot.send_animation(
                TAKES_CHANNEL,
                animation=message.animation.file_id,
                caption=censored_caption if has_profanity else raw_caption,
                parse_mode="HTML" if has_profanity else None,
            )

        elif message.voice:
            raw_caption = message.caption or ""
            censored_caption, has_profanity = censor_profanity(raw_caption)
            sent_message = await bot.send_voice(
                TAKES_CHANNEL,
                voice=message.voice.file_id,
                caption=censored_caption if has_profanity else raw_caption,
                parse_mode="HTML" if has_profanity else None,
            )

        elif message.audio:
            raw_caption = message.caption or ""
            censored_caption, has_profanity = censor_profanity(raw_caption)
            sent_message = await bot.send_audio(
                TAKES_CHANNEL,
                audio=message.audio.file_id,
                caption=censored_caption if has_profanity else raw_caption,
                parse_mode="HTML" if has_profanity else None,
            )

        elif message.sticker:
            sent_message = await bot.send_sticker(TAKES_CHANNEL, sticker=message.sticker.file_id)

        else:
            raw_text = message.text or ""
            censored_text, has_profanity = censor_profanity(raw_text)
            sent_message = await bot.send_message(
                TAKES_CHANNEL,
                censored_text if has_profanity else raw_text,
                parse_mode="HTML" if has_profanity else None,
            )

        if sent_message:
            await send_take_to_admin(message, user_id, sent_message.message_id)
        
        return sent_message
    except Exception as e:
        logger.error(f"Error forwarding take to channel: {e}")
        return None

