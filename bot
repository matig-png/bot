async def promo_pay(callback: types.CallbackQuery, state: FSMContext) -> None:
    data = await state.get_data()
    user_id = callback.from_user.id
    total_cost = data['total_cost']
    
    user_balance = get_user_balance(user_id)
    
    if user_balance != float('inf') and user_balance < total_cost:
        await callback.answer("Недостаточно лун на счёте!", show_alert=True)
        return
    
    if user_balance != float('inf'):
        deduct_moons(user_id, total_cost)
    
    post_data = data['post_data']
    hours = data['hours']
    is_pinned = data['is_pinned']
    
    try:
        sent_msg = None
        if post_data['photo']:
            sent_msg = await bot.send_photo(
                TAKES_CHANNEL,
                photo=post_data['photo'],
                caption=post_data['caption']
            )
        elif post_data['video']:
            sent_msg = await bot.send_video(
                TAKES_CHANNEL,
                video=post_data['video'],
                caption=post_data['caption']
            )
        elif post_data['text']:
            sent_msg = await bot.send_message(TAKES_CHANNEL, post_data['text'])
        
        if sent_msg and is_pinned:
            try:
                await bot.pin_chat_message(TAKES_CHANNEL, sent_msg.message_id)
            except Exception as e:
                logger.error(f"Error pinning message: {e}")
        
        if sent_msg:
            async def delete_after_delay():
                await asyncio.sleep(hours * 3600)
                try:
                    if is_pinned:
                        await bot.unpin_chat_message(TAKES_CHANNEL, sent_msg.message_id)
                    await bot.delete_message(TAKES_CHANNEL, sent_msg.message_id)
                except Exception as e:
                    logger.error(f"Error deleting promo: {e}")
            
            task = asyncio.create_task(delete_after_delay())
            scheduled_deletions[str(sent_msg.message_id)] = task
        
        await callback.message.edit_text(
            f"✅ Пиар успешно оплачен и размещён!\n"
            f"Пост будет удалён через {hours} ч.",
            reply_markup=build_main_menu()
        )
    except Exception as e:
        logger.error(f"Error posting promo: {e}")
        add_moons(user_id, total_cost)
        await callback.message.edit_text(
            "❌ Ошибка при размещении. Луны возвращены.",
            reply_markup=build_main_menu()
        )
    
    await state.clear()
    await callback.answer()

