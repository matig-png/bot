def create_connection_handlers(bot_instance: Bot, dp: Dispatcher):
    router = Router()

    @router.callback_query(F.data == "connect_bot")
    async def conn(callback: types.CallbackQuery, state: FSMContext):
        await callback.message.edit_text("🤖 Ссылка на канал:", reply_markup=build_cancel_keyboard())
        await state.set_state(ConnectBotStates.WaitingChannelUrl)
        await callback.answer()

    @router.message(ConnectBotStates.WaitingChannelUrl)
    async def conn_ch(message: types.Message, state: FSMContext):
        rid = str(uuid.uuid4())[:8]
        req = PendingBotRequest(request_id=rid, user_id=message.from_user.id, channel_url=message.text.strip())
        storage.pending_requests[rid] = req
        storage.save()
        user = storage.users.get(message.from_user.id)
        kb = InlineKeyboardMarkup(inline_keyboard=[[
            InlineKeyboardButton(text="✅", callback_data=f"request_approve_{rid}"),
            InlineKeyboardButton(text="❌", callback_data=f"request_reject_{rid}")
        ]])
        try:
            await bot_instance.send_message(MAIN_ADMIN_ID, f"📝 Заявка\n@{user.username if user else '?'}\n{message.text}", reply_markup=kb)
        except Exception:
            pass
        await message.answer("✅ Отправлено!", reply_markup=build_main_menu("main"))
        await state.clear()

    @router.callback_query(F.data.startswith("request_approve_"))
    async def req_ok(callback: types.CallbackQuery):
        if callback.from_user.id != MAIN_ADMIN_ID:
            await callback.answer("Нет", show_alert=True)
            return
        rid = callback.data[16:]
        req = storage.pending_requests.get(rid)
        if not req:
            await callback.answer("Нет", show_alert=True)
            return
        kb = InlineKeyboardMarkup(inline_keyboard=[[
            InlineKeyboardButton(text="✅ Да", callback_data=f"request_confirm_{rid}"),
            InlineKeyboardButton(text="❌ Нет", callback_data=f"request_back_{rid}")
        ]])
        await callback.message.edit_text("Уверены?", reply_markup=kb)
        await callback.answer()

    @router.callback_query(F.data.startswith("request_back_"))
    async def req_bk(callback: types.CallbackQuery):
        rid = callback.data[13:]
        req = storage.pending_requests.get(rid)
        if req:
            user = storage.users.get(req.user_id)
            kb = InlineKeyboardMarkup(inline_keyboard=[[
                InlineKeyboardButton(text="✅", callback_data=f"request_approve_{rid}"),
                InlineKeyboardButton(text="❌", callback_data=f"request_reject_{rid}")
            ]])
            await callback.message.edit_text(f"📝 @{user.username if user else '?'}\n{req.channel_url}", reply_markup=kb)
        await callback.answer()

    @router.callback_query(F.data.startswith("request_confirm_"))
    async def req_cf(callback: types.CallbackQuery):
        if callback.from_user.id != MAIN_ADMIN_ID:
            await callback.answer("Нет", show_alert=True)
            return
        rid = callback.data[16:]
        req = storage.pending_requests.get(rid)
        if not req:
            await callback.answer("Нет", show_alert=True)
            return
        req.status = "token_wait"
        storage.waiting_for_token[req.user_id] = rid
        storage.save()
        try:
            await bot_instance.send_message(req.user_id, "✅ Одобрено!\nТокен от @BotFather:")
            await callback.message.edit_text("⏳ Ждём токен...")
        except Exception as e:
            await callback.message.edit_text(f"❌ {e}")
        await callback.answer()

    @router.callback_query(F.data.startswith("request_reject_"))
    async def req_no(callback: types.CallbackQuery):
        if callback.from_user.id != MAIN_ADMIN_ID:
            await callback.answer("Нет", show_alert=True)
            return
        rid = callback.data[15:]
        req = storage.pending_requests.get(rid)
        if req:
            try:
                await bot_instance.send_message(req.user_id, "❌ Отклонено.")
            except Exception:
                pass
            del storage.pending_requests[rid]
            storage.save()
        await callback.message.edit_text("❌")
        await callback.answer()

    @router.message(F.text.regexp(r'^\d{8,10}:[A-Za-z0-9_-]{35,}$'))
    async def recv_tok(message: types.Message, state: FSMContext):
        uid = message.from_user.id
        if uid not in storage.waiting_for_token:
            return
        rid = storage.waiting_for_token[uid]
        req = storage.pending_requests.get(rid)
        if not req or req.status != "token_wait":
            del storage.waiting_for_token[uid]
            return
        try:
            tb = Bot(token=message.text.strip())
            info = await tb.get_me()
            await tb.session.close()
            req.token = message.text.strip()
            req.status = "configuring"
            del storage.waiting_for_token[uid]
            storage.save()
            await state.update_data(request_id=rid)
            await message.answer(f"✅ @{info.username}\n\nНазвание валюты:")
            await state.set_state(ConnectBotStates.WaitingCurrencyName)
            try:
                await bot_instance.send_message(MAIN_ADMIN_ID, f"✅ @{info.username}")
            except Exception:
                pass
        except Exception as e:
            await message.answer(f"❌ {e}\nЕщё раз:")

