    async def finish(msg, state, req, main_bot):
        await msg.answer("⏳...")
        try:
            nid = f"bot_{req.user_id}_{int(datetime.now().timestamp())}"
            ncfg = BotConfig(bot_id=nid, token=req.token, currency_name=req.currency_name,
                currency_emoji=req.currency_emoji, channel_url=req.channel_url,
                takes_channel=req.takes_channel, shop_channel=req.shop_channel,
                modules=req.modules, owner_id=req.user_id, base_exchange_rate=0.5, take_cooldown_minutes=3)
            cfg_storage.bots[nid] = ncfg
            # Настройка владельца в БД
            get_or_create_user(msg.from_user, nid)
            db.set_balance(req.user_id, nid, float('inf'))
            db.set_bot_data(req.user_id, nid, is_owner=1, is_admin=1, activated_at=datetime.now().isoformat())
            cfg_storage.exchange_rates.rates[nid] = 0.5
            if req.request_id in cfg_storage.pending_requests: del cfg_storage.pending_requests[req.request_id]
            cfg_storage.save()
            nb = Bot(token=req.token); nd = Dispatcher(storage=MemoryStorage())
            create_bot_handlers(nid, nb, nd)
            cfg_storage.active_bots[nid] = nb; cfg_storage.active_dispatchers[nid] = nd
            asyncio.create_task(nd.start_polling(nb))
            await msg.answer(f"✅ {req.currency_name} {req.currency_emoji}\n{', '.join(req.modules)}\n\n/start в боте", reply_markup=build_main_menu("main"))
        except Exception as e: logger.error(f"Запуск: {e}"); await msg.answer(f"❌ {e}", reply_markup=build_main_menu("main"))
        await state.clear()

    dp.include_router(router)


# ====================== MAIN ======================

async def main():
    db.connect()
    cfg_storage.load()

    main_bot = Bot(token=MAIN_BOT_TOKEN)
    main_dp = Dispatcher(storage=MemoryStorage())
    create_bot_handlers("main", main_bot, main_dp)
    create_connection_handlers(main_bot, main_dp)
    cfg_storage.active_bots["main"] = main_bot
    cfg_storage.active_dispatchers["main"] = main_dp

    for bid, cfg in cfg_storage.bots.items():
        if bid != "main":
            try:
                cb = Bot(token=cfg.token); cd = Dispatcher(storage=MemoryStorage())
                create_bot_handlers(bid, cb, cd)
                cfg_storage.active_bots[bid] = cb; cfg_storage.active_dispatchers[bid] = cd
                asyncio.create_task(cd.start_polling(cb))
                logger.info(f"Запущен: {bid}")
            except Exception as e: logger.error(f"{bid}: {e}")

    # Восстановление удалений
    now = datetime.now(); rm = []
    for did, info in cfg_storage.scheduled_deletions.items():
        try:
            da = datetime.fromisoformat(info['delete_at'])
            tb = cfg_storage.active_bots.get(info['bot_id'])
            if not tb: rm.append(did); continue
            if da <= now:
                try:
                    if info.get('is_pinned'): await tb.unpin_chat_message(info['channel'], info['message_id'])
                    await tb.delete_message(info['channel'], info['message_id'])
                except: pass
                rm.append(did)
            else:
                h = (da - now).total_seconds() / 3600
                asyncio.create_task(delayed_delete_message(tb, info['channel'], info['message_id'], h, info.get('is_pinned', False), did))
        except: rm.append(did)
    for d in rm:
        if d in cfg_storage.scheduled_deletions: del cfg_storage.scheduled_deletions[d]
    if rm: cfg_storage.save()

    logger.info("Запуск...")
    await main_dp.start_polling(main_bot)


if __name__ == "__main__":
    print("🚀 Запуск бота...")
    asyncio.run(main())
