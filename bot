def get_last_take_time(user_id: int, bot_id: str) -> Optional[datetime]:
    """Время последнего тейка."""
    if user_id not in storage.users:
        return None
    timestamps = storage.users[user_id].takes_timestamps.get(bot_id, [])
    if not timestamps:
        return None
    try:
        return datetime.fromisoformat(timestamps[-1])
    except Exception:
        return None


def can_send_take(user_id: int, bot_id: str) -> Tuple[bool, str]:
    """Проверка кулдауна тейков."""
    bot_config = storage.bots.get(bot_id)
    if not bot_config:
        return False, "Ошибка конфигурации"

    last_time = get_last_take_time(user_id, bot_id)
    if last_time is None:
        return True, "Можно отправить"

    cooldown = timedelta(minutes=bot_config.take_cooldown_minutes)
    next_available = last_time + cooldown
    now = datetime.now()

    if now >= next_available:
        return True, "Можно отправить"

    remaining = next_available - now
    minutes = int(remaining.total_seconds() // 60)
    seconds = int(remaining.total_seconds() % 60)

    return False, f"Подождите {minutes}м {seconds}с"


def add_take_timestamp(user_id: int, bot_id: str):
    """Записать время отправки тейка."""
    if user_id not in storage.users:
        return
    user = storage.users[user_id]
    if bot_id not in user.takes_timestamps:
        user.takes_timestamps[bot_id] = []
    user.takes_timestamps[bot_id].append(datetime.now().isoformat())
    if len(user.takes_timestamps[bot_id]) > 10:
        user.takes_timestamps[bot_id] = user.takes_timestamps[bot_id][-10:]
    storage.save()


