async def run_auction_timer(bot_instance: Bot, bot_id: str, channel: str, 
                             message_id: int, auction_id: str):
    """Таймер аукциона: ждёт 4 мин, потом обратный отсчёт."""
    cfg = cfg_storage.bots.get(bot_id)
    if not cfg:
        return
    
    try:
        while True:
            auction = cfg_storage.active_auctions.get(auction_id)
            if not auction:
                return
            
            # Ждём 4 минуты с последней ставки
            last_bid_time = datetime.fromisoformat(auction.get('last_bid_time', datetime.now().isoformat()))
            wait_until = last_bid_time + timedelta(minutes=4)
            
            now = datetime.now()
            if now < wait_until:
                await asyncio.sleep((wait_until - now).total_seconds())
            
            # Проверяем не было ли новой ставки
            auction = cfg_storage.active_auctions.get(auction_id)
            if not auction:
                return
            
            new_last = datetime.fromisoformat(auction.get('last_bid_time', ''))
            if new_last > last_bid_time:
                continue  # Новая ставка — сброс
            
            # Обратный отсчёт: 3, 2, 1
            for count in [3, 2, 1]:
                auction = cfg_storage.active_auctions.get(auction_id)
                if not auction:
                    return
                
                try:
                    await bot_instance.send_message(
                        channel, str(count),
                        reply_to_message_id=message_id
                    )
                except Exception:
                    pass
                
                await asyncio.sleep(30)
                
                # Проверяем новую ставку
                auction = cfg_storage.active_auctions.get(auction_id)
                if not auction:
                    return
                new_last2 = datetime.fromisoformat(auction.get('last_bid_time', ''))
                if new_last2 > new_last:
                    break  # Новая ставка — сброс
            else:
                # Обратный отсчёт завершён — объявляем победителя
                auction = cfg_storage.active_auctions.get(auction_id)
                if not auction:
                    return
                
                winner_id = auction.get('current_bidder')
                winner_amount = auction.get('current_bid', 0)
                
                if winner_id:
                    winner = db.get_user(winner_id)
                    winner_name = winner['name'] if winner else "Неизвестный"
                    
                    try:
                        await bot_instance.send_message(
                            channel,
                            f"🏆 {winner_name}, вы выиграли аукцион!\n"
                            f"💰 Ставка: {winner_amount} {cfg.currency_emoji}",
                            reply_to_message_id=message_id
                        )
                    except Exception:
                        pass
                    
                    # Списываем со счёта
                    db.deduct_balance(winner_id, bot_id, winner_amount)
                
                # Удаляем аукцион
                if auction_id in cfg_storage.active_auctions:
                    del cfg_storage.active_auctions[auction_id]
                    cfg_storage.save()
                return
                
    except asyncio.CancelledError:
        pass
    except Exception as e:
        logger.error(f"Аукцион: {e}")

