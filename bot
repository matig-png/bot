@dp.message(TakeStates.WaitingTake)
async def process_take(message: types.Message, state: FSMContext) -> None:
    uid = message.from_user.id
    
    if is_user_blocked(uid):
        await message.answer("🚫 Вы заблокированы.", reply_markup=build_main_menu())
        await state.clear()
        return

    can_send, remaining = can_send_take(uid)
    if not can_send:
        time_until = get_time_until_reset(uid)
        await message.answer(
            f"❌ Вы исчерпали лимит тейков!\nСледующий через: {time_until}",
            reply_markup=build_main_menu()
        )
        await state.clear()
        return

    if not message_contains_take_hashtag(message):
        await message.answer(
            "⚠️ Добавьте #тейк в конец сообщения\n\n"
            "Отправьте сообщение ещё раз с хештегом #тейк",
            reply_markup=build_cancel_keyboard()
        )
        return

    sent_msg = await forward_take_to_channel(message, uid)

    if sent_msg:
        add_take_timestamp(uid)
        _, new_remaining = can_send_take(uid)

        await message.answer(
            f"✅ Ваш тейк успешно отправлен в канал!\n\n"
            f"📊 Осталось тейков сегодня: {new_remaining}/{MAX_TAKES_PER_DAY}",
            reply_markup=build_main_menu()
        )
    else:
        await message.answer(
            "❌ Ошибка при отправке тейка. Попробуйте позже.",
            reply_markup=build_main_menu()
        )

    await state.clear()

