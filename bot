                cfg = storage.bots.get(bot_id)

                if not deduct_balance(callback.from_user.id, bot_id, total):
                    await callback.answer("Недостаточно средств", show_alert=True)
                    return

                post = data.get('post', {})
                try:
                    if post.get('photo'):
                        sent = await bot_instance.send_photo(
                            cfg.takes_channel, photo=post['photo'],
                            caption=post.get('caption')
                        )
                    elif post.get('video'):
                        sent = await bot_instance.send_video(
                            cfg.takes_channel, video=post['video'],
                            caption=post.get('caption')
                        )
                    else:
                        sent = await bot_instance.send_message(cfg.takes_channel, post.get('text', ''))

                    if data.get('pinned'):
                        try:
                            await bot_instance.pin_chat_message(cfg.takes_channel, sent.message_id)
                        except: pass

                    hours = data.get('hours', 1)
                    
                    async def delete_later():
                        await asyncio.sleep(hours * 3600)
                        try:
                            if data.get('pinned'):
                                await bot_instance.unpin_chat_message(cfg.takes_channel, sent.message_id)
                            await bot_instance.delete_message(cfg.takes_channel, sent.message_id)
                        except: pass

                    asyncio.create_task(delete_later())
                    await callback.message.edit_text(
                        f"✅ Пиар размещён на {hours}ч",
                        reply_markup=build_main_menu(bot_id)
                    )
                except Exception as e:
                    add_balance(callback.from_user.id, bot_id, total)
                    await callback.message.edit_text(f"❌ Ошибка: {e}", reply_markup=build_main_menu(bot_id))
                await state.clear()
                await callback.answer()
                return
                
            pinned = callback.data == "promo_pinned"
            cfg = storage.bots.get(bot_id)
            price = cfg.promo_pin_price_per_hour if pinned else cfg.promo_price_per_hour
            await state.update_data(pinned=pinned, price_per_hour=price)
