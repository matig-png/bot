    return [{'type': e.type, 'offset': e.offset, 'length': e.length,
             'url': e.url, 'language': e.language, 'custom_emoji_id': e.custom_emoji_id}
            for e in entities]

def restore_entities(data: Optional[List[Dict]]) -> Optional[List[MessageEntity]]:
