    if config and "takes" in config.modules:

        async def process_take(message: types.Message, bid: str, bot: Bot):
            uid = message.from_user.id
            get_or_create_user(message.from_user, bid)
            cfg = cfg_storage.bots.get(bid)
            d = db.get_bot_data(uid, bid)

            if d.get('is_blocked'):
                await message.answer("🚫 Заблокированы."); return False
            can_t, cmsg = can_send_take(uid, bid)
            if not can_t:
                await message.answer(f"⏳ {cmsg}"); return False

            text = message.text or message.caption or ""

            # Тейки на паузе → в очередь
            if cfg.takes_paused:
                take_data = {
                    'user_id': uid, 'bot_id': bid, 'text': text,
                    'photo': message.photo[-1].file_id if message.photo else None,
                    'video': message.video.file_id if message.video else None,
                    'caption': message.caption, 'timestamp': datetime.now().isoformat()
                }
                if bid not in cfg_storage.paused_takes:
                    cfg_storage.paused_takes[bid] = []
                cfg_storage.paused_takes[bid].append(take_data)
                cfg_storage.save()
                db.add_take_timestamp(uid, bid)
                await message.answer("⏸ Тейки на паузе. Будет отправлен когда включат.", reply_markup=build_main_menu(bid))
                return True

            # Ручной контроль → всё на модерацию
            needs_mod = cfg.manual_control
            mod_reason = "Ручной контроль"

            if not needs_mod:
                needs_mod = contains_marker_words(text, bid)
                mod_reason = "Маркерное слово"

            if not needs_mod:
                has_group, link_reason = await check_telegram_links(text, bot)
                if has_group:
                    needs_mod = True
                    mod_reason = link_reason

            if needs_mod:
                take_id = str(uuid.uuid4())[:8]
                cfg_storage.pending_takes[take_id] = {
                    'user_id': uid, 'bot_id': bid, 'text': text,
                    'photo': message.photo[-1].file_id if message.photo else None,
                    'video': message.video.file_id if message.video else None,
                    'animation': message.animation.file_id if message.animation else None,
                    'document': message.document.file_id if message.document else None,
                    'caption': message.caption
                }
                cfg_storage.save()

                for mod_uid in [u['user_id'] for u in db.get_all_users_for_bot(bid)]:
                    if is_moderator(mod_uid, bid):
                        try:
                            bl = db.get_bot_data(uid, bid).get('is_blocked', 0)
                            await bot.send_message(mod_uid,
                                f"⚠️ Модерация\nПричина: {mod_reason}\n\n{text}",
                                reply_markup=build_take_mod_kb(take_id, uid, bool(bl)))
                            await message.copy_to(mod_uid)
                        except: pass

                await message.answer("📝 На модерации.", reply_markup=build_main_menu(bid))
                return True
            else:
                sent = await forward_take_to_channel(message, bid, bot)
                if sent:
                    db.add_take_timestamp(uid, bid)
                    await message.answer("✅ Отправлено!", reply_markup=build_main_menu(bid))
                    return True
                await message.answer("❌ Ошибка.", reply_markup=build_main_menu(bid))
                return False

