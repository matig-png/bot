def find_user_by_input(input_str: str) -> Optional[int]:
    """Найти пользователя по username, имени или ID."""
    input_str = input_str.strip().lstrip('@').lower()
    try:
        uid = int(input_str)
        if uid in storage.users:
            return uid
    except ValueError:
        pass
    for uid, data in storage.users.items():
        if data.username.lower() == input_str or data.name.lower() == input_str:
            return uid
    return None


# ====================== УПРАВЛЕНИЕ ТЕЙКАМИ ======================

def get_takes_count_24h(user_id: int, bot_id: str) -> int:
    """Количество тейков за 24 часа."""
    if user_id not in storage.users:
        return 0
    user = storage.users[user_id]
    timestamps = user.takes_timestamps.get(bot_id, [])
    now = datetime.now()
    cutoff = now - timedelta(hours=24)
    valid = [ts for ts in timestamps if datetime.fromisoformat(ts) > cutoff]
    user.takes_timestamps[bot_id] = valid
    return len(valid)


def can_send_take(user_id: int, bot_id: str) -> Tuple[bool, int]:
    """Может ли пользователь отправить тейк."""
    bot_config = storage.bots.get(bot_id)
    if not bot_config:
        return False, 0
    count = get_takes_count_24h(user_id, bot_id)
    remaining = bot_config.max_takes_per_day - count
    return remaining > 0, max(0, remaining)


def add_take_timestamp(user_id: int, bot_id: str):
    """Записать время отправки тейка."""
    if user_id not in storage.users:
        return
    user = storage.users[user_id]
    if bot_id not in user.takes_timestamps:
        user.takes_timestamps[bot_id] = []
    user.takes_timestamps[bot_id].append(datetime.now().isoformat())
    storage.save()


