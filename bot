    @router.callback_query(F.data == "adm_toggle_takes")
    async def toggle_takes(cb: types.CallbackQuery):
        if not is_owner(cb.from_user.id, bot_id): await cb.answer("Нет", show_alert=True); return
        cfg = cfg_storage.bots.get(bot_id)
        if cfg.takes_paused:
            # Включаем — отправляем накопленные
            cfg.takes_paused = False
            paused = cfg_storage.paused_takes.get(bot_id, [])
            sent_count = 0
            for take in paused:
                text = take.get('text', '')
                # Проверяем на модерацию
                if contains_marker_words(text, bot_id) or cfg.manual_control:
                    tid = str(uuid.uuid4())[:8]
                    cfg_storage.pending_takes[tid] = take
                else:
                    try:
                        censored, hp = censor_profanity(text, bot_id)
                        kw = {"caption": censored if hp else text, "parse_mode": "HTML" if hp else None}
                        if take.get('photo'):
                            await bot_instance.send_photo(cfg.takes_channel, photo=take['photo'], **kw)
                        else:
                            await bot_instance.send_message(cfg.takes_channel, censored if hp else text, parse_mode="HTML" if hp else None)
                        sent_count += 1
                    except: pass
            cfg_storage.paused_takes[bot_id] = []
            cfg_storage.save()
            await cb.answer(f"▶️ Тейки включены! Отправлено: {sent_count}", show_alert=True)
        else:
            cfg.takes_paused = True
            cfg_storage.save()
            await cb.answer("⏸ Тейки на паузе", show_alert=True)
        await cb.message.edit_text("Админ:", reply_markup=build_admin_menu(cb.from_user.id, bot_id))

