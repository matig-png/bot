    uid = user.id
    username = user.username or f"user{uid}"
    name = user.full_name

    if uid not in storage.users:
        storage.users[uid] = UserData(
            user_id=uid,
            username=username,
            name=name
        )

    user_data = storage.users[uid]
    user_data.username = username
