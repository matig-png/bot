def find_user_by_input(inp: str) -> Optional[int]:
    inp = inp.strip().lstrip('@').lower()
    try:
        uid = int(inp)
        if db.get_user(uid):
            return uid
    except ValueError:
        pass
    # Поиск по username — через прямой SQL
    cursor = db.conn.cursor()
    cursor.execute('SELECT user_id FROM users WHERE LOWER(username) = ? OR LOWER(name) = ?', (inp, inp))
    row = cursor.fetchone()
    return row['user_id'] if row else None

def can_send_take(uid: int, bot_id: str) -> Tuple[bool, str]:
    cfg = cfg_storage.bots.get(bot_id)
    if not cfg:
        return False, "Ошибка"
    last = db.get_last_take_time(uid, bot_id)
    if not last:
        return True, "Доступно"
    try:
        last_dt = datetime.fromisoformat(last)
    except Exception:
        return True, "Доступно"
    next_avail = last_dt + timedelta(minutes=cfg.take_cooldown_minutes)
    now = datetime.now()
    if now >= next_avail:
        return True, "Доступно"
    rem = next_avail - now
    return False, f"Подождите {int(rem.total_seconds()//60)}м {int(rem.total_seconds()%60)}с"

def can_use_promo(uid: int, bot_id: str) -> Tuple[bool, str]:
    """Проверка: прошло ли 3 дня с активации и 12ч с последнего пиара."""
    d = db.get_bot_data(uid, bot_id)

    # Проверка 3 дня с активации
    activated = d.get('activated_at', '')
    if activated:
        try:
            act_dt = datetime.fromisoformat(activated)
            if datetime.now() - act_dt < timedelta(days=3):
                remaining = (act_dt + timedelta(days=3)) - datetime.now()
                hours = int(remaining.total_seconds() // 3600)
                return False, f"Пиар доступен через {hours}ч (3 дня с активации)"
        except Exception:
            pass

    # Проверка 12 часов
    last_promo = d.get('last_promo_at', '')
    if last_promo:
        try:
            last_dt = datetime.fromisoformat(last_promo)
            if datetime.now() - last_dt < timedelta(hours=12):
                remaining = (last_dt + timedelta(hours=12)) - datetime.now()
                hours = int(remaining.total_seconds() // 3600)
                mins = int((remaining.total_seconds() % 3600) // 60)
                return False, f"Подождите {hours}ч {mins}м"
        except Exception:
            pass

    return True, "Доступно"

def transfer_balance(sender_id: int, receiver_id: int, bot_id: str, amount: float) -> Tuple[bool, str]:
    sd = db.get_bot_data(sender_id, bot_id)
    rd = db.get_bot_data(receiver_id, bot_id)
    if sd.get('is_frozen'):
        return False, "Ваш счёт заморожен"
    if rd.get('is_frozen'):
        return False, "Счёт получателя заморожен"
    sb = db.get_balance(sender_id, bot_id)
    if sb != float('inf') and sb < amount:
        return False, "Недостаточно средств"
    if sb != float('inf'):
        db.set_balance(sender_id, bot_id, sb - amount)
    db.add_balance(receiver_id, bot_id, amount)
    return True, "OK"

def get_exchange_rate(bot_id: str) -> float:
    if cfg_storage.exchange_rates.rates_locked:
        cfg = cfg_storage.bots.get(bot_id)
        return cfg.base_exchange_rate if cfg else 0.5
    return cfg_storage.exchange_rates.rates.get(bot_id, 0.5)

def convert_currency(uid: int, from_bot: str, to_bot: str, amount: float) -> Tuple[bool, float, str]:
    fb = db.get_balance(uid, from_bot)
    if fb == float('inf'):
        return False, 0, "Владельцы не могут"
    if fb < amount:
        return False, 0, "Недостаточно"
    fr, tr = get_exchange_rate(from_bot), get_exchange_rate(to_bot)
    converted = amount * fr / tr
    db.set_balance(uid, from_bot, fb - amount)
    db.add_balance(uid, to_bot, converted)
    return True, converted, "OK"

def reset_exchange_rates():
    cfg_storage.exchange_rates.rates_locked = True
    cfg_storage.exchange_rates.rates = {"main": 1.0}
    for bid, cfg in cfg_storage.bots.items():
        if bid != "main":
            cfg_storage.exchange_rates.rates[bid] = cfg.base_exchange_rate
    cfg_storage.save()

