async def forward_take_to_channel(message: types.Message, bot_id: str, bot_instance: Bot) -> Optional[types.Message]:
    try:
        cfg = cfg_storage.bots.get(bot_id)
        if not cfg or not cfg.takes_channel:
            return None
        text = message.text or message.caption or ""
        censored, has_prof = censor_profanity(text, bot_id)
        kw = {"caption": censored if has_prof else text, "parse_mode": "HTML" if has_prof else None}

        if message.photo:
            return await bot_instance.send_photo(cfg.takes_channel, photo=message.photo[-1].file_id, **kw)
        elif message.video:
            return await bot_instance.send_video(cfg.takes_channel, video=message.video.file_id, **kw)
        elif message.animation:
            return await bot_instance.send_animation(cfg.takes_channel, animation=message.animation.file_id, **kw)
        elif message.document:
            return await bot_instance.send_document(cfg.takes_channel, document=message.document.file_id, **kw)
        elif message.voice:
            return await bot_instance.send_voice(cfg.takes_channel, voice=message.voice.file_id, **kw)
        elif message.audio:
            return await bot_instance.send_audio(cfg.takes_channel, audio=message.audio.file_id, **kw)
        elif message.sticker:
            return await bot_instance.send_sticker(cfg.takes_channel, sticker=message.sticker.file_id)
        else:
            return await bot_instance.send_message(cfg.takes_channel, censored if has_prof else text, parse_mode="HTML" if has_prof else None)
    except Exception as e:
        logger.error(f"Пересылка тейка: {e}")
        return None


