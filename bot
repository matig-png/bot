        async def process_take_message(message: types.Message, bot_id: str, bot_inst: Bot):
            """Общая логика обработки тейка (кнопка и автоотправка)."""
            uid = message.from_user.id

            if uid not in storage.users:
                get_or_create_user(message.from_user, bot_id)

            user = storage.users.get(uid)
            cfg = storage.bots.get(bot_id)

            # Проверка блокировки
            if user and user.is_blocked.get(bot_id, False):
                await message.answer("🚫 Вы заблокированы для отправки тейков.")
                return False

            # Проверка лимита
            can_take, remaining = can_send_take(uid, bot_id)
            if not can_take:
                await message.answer(f"❌ Лимит тейков исчерпан ({cfg.max_takes_per_day} в 24ч)")
                return False

            text = message.text or message.caption or ""

            # Проверка на маркерные слова → отправка на модерацию
            if contains_marker_words(text, bot_id):
                take_id = str(uuid.uuid4())[:8]
                storage.pending_takes[take_id] = {
                    'user_id': uid,
                    'bot_id': bot_id,
                    'text': text,
                    'photo': message.photo[-1].file_id if message.photo else None,
                    'video': message.video.file_id if message.video else None,
                    'animation': message.animation.file_id if message.animation else None,
                    'document': message.document.file_id if message.document else None,
                    'voice': message.voice.file_id if message.voice else None,
                    'audio': message.audio.file_id if message.audio else None,
                    'sticker': message.sticker.file_id if message.sticker else None,
                    'caption': message.caption
                }
                storage.save()

                # Уведомляем модераторов
                for mod_uid, mod_user in storage.users.items():
                    if is_moderator(mod_uid, bot_id):
                        try:
                            user_blocked = storage.users[uid].is_blocked.get(bot_id, False)
                            await bot_inst.send_message(
                                mod_uid,
                                f"⚠️ Тейк на модерации\n"
                                f"От: @{user.username}\n\n{text}",
                                reply_markup=build_take_moderation_keyboard(take_id, uid, user_blocked)
                            )
                            await message.forward(mod_uid)
                        except Exception as e:
                            logger.error(f"Ошибка отправки модератору {mod_uid}: {e}")

                await message.answer("📝 Тейк отправлен на модерацию.", reply_markup=build_main_menu(bot_id))
                return True
            else:
                # Отправляем напрямую в канал
                sent = await forward_take_to_channel(message, bot_id, bot_inst)
                if sent:
                    add_take_timestamp(uid, bot_id)
                    _, remaining = can_send_take(uid, bot_id)
                    await message.answer(
                        f"✅ Тейк отправлен в канал!\n"
                        f"📊 Осталось: {remaining}/{cfg.max_takes_per_day}",
                        reply_markup=build_main_menu(bot_id)
                    )
                    return True
                else:
                    await message.answer("❌ Ошибка при отправке тейка.", reply_markup=build_main_menu(bot_id))
                    return False

