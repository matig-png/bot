    # Приём токена бота
    @router.message(F.text.regexp(r'^\d{8,10}:[A-Za-z0-9_-]{35,}$'))
    async def receive_bot_token(message: types.Message, state: FSMContext):
        uid = message.from_user.id
        if uid not in storage.waiting_for_token:
            return

        request_id = storage.waiting_for_token[uid]
        request = storage.pending_requests.get(request_id)
        if not request or request.status != "token_wait":
            del storage.waiting_for_token[uid]
            return

        token = message.text.strip()
        try:
            test_bot = Bot(token=token)
            bot_info = await test_bot.get_me()
            await test_bot.session.close()

            request.token = token
            request.status = "configuring"
            del storage.waiting_for_token[uid]
            storage.save()

            await state.update_data(request_id=request_id)
            await message.answer(
                f"✅ Бот найден: @{bot_info.username}\n\n"
                f"Как будет называться валюта?"
            )
            await state.set_state(ConnectBotStates.WaitingCurrencyName)

            try:
                await bot_instance.send_message(MAIN_ADMIN_ID, f"✅ Токен получен: @{bot_info.username}")
            except Exception:
                pass
        except Exception as e:
            await message.answer(f"❌ Неверный токен: {e}\nПопробуйте ещё раз:")

