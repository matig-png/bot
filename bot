@dp.callback_query(F.data.startswith("block_user:"))
async def block_user_callback(callback: types.CallbackQuery) -> None:
    if callback.from_user.id not in ADMIN_IDS:
        await callback.answer("Доступ запрещен", show_alert=True)
        return
    
    user_id = int(callback.data.split(":")[1])
    block_user(user_id)
    
    channel_msg_id = None
    for msg_id, data in sent_takes.items():
        if data['user_id'] == user_id:
            channel_msg_id = msg_id
            break
    
    await callback.message.edit_reply_markup(
        reply_markup=build_admin_take_keyboard(user_id, channel_msg_id or "0", True)
    )
    await callback.answer(f"Пользователь {user_id} заблокирован", show_alert=True)

