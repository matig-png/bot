def get_takes_count_last_24h(user_id: int) -> int:
    if user_id not in users:
        return 0
    now = datetime.now()
    cutoff = now - timedelta(hours=24)
    valid_timestamps = []
    for ts_str in users[user_id].get('takes_timestamps', []):
        try:
            ts = datetime.fromisoformat(ts_str)
            if ts > cutoff:
                valid_timestamps.append(ts_str)
        except:
            continue
    users[user_id]['takes_timestamps'] = valid_timestamps
    return len(valid_timestamps)

def add_take_timestamp(user_id: int) -> None:
    if user_id not in users:
        return
    if 'takes_timestamps' not in users[user_id]:
        users[user_id]['takes_timestamps'] = []
    users[user_id]['takes_timestamps'].append(datetime.now().isoformat())
    save_data()

def can_send_take(user_id: int) -> Tuple[bool, int]:
    count = get_takes_count_last_24h(user_id)
    remaining = MAX_TAKES_PER_DAY - count
    return remaining > 0, remaining

def get_time_until_reset(user_id: int) -> str:
    if user_id not in users:
        return "неизвестно"
    timestamps = users[user_id].get('takes_timestamps', [])
    if not timestamps:
        return "сейчас"
    try:
        oldest = min(datetime.fromisoformat(ts) for ts in timestamps)
        reset_time = oldest + timedelta(hours=24)
        now = datetime.now()
        if reset_time <= now:
            return "сейчас"
        diff = reset_time - now
        hours = diff.seconds // 3600
        minutes = (diff.seconds % 3600) // 60
        return f"{hours}ч {minutes}мин"
    except:
        return "неизвестно"

def register_user(user: User) -> None:
    uid = user.id
    username = user.username or f"user{uid}"
    name = user.full_name

    if uid in user_id_to_username and user_id_to_username[uid] != username:
        logger.info(f"Username changed for user {uid}: {user_id_to_username[uid]} -> {username}")

    user_id_to_username[uid] = username

    if uid not in users:
        is_admin = uid in ADMIN_IDS
        moons = float('inf') if uid == MAIN_ADMIN_ID else (ADMIN_STARTING_BALANCE if is_admin else 0)
        users[uid] = {
            "username": username,
            "name": name,
            "moons": moons,
            "quiz_passed": False,
            "is_admin": is_admin,
            "show_in_top": True,
            "takes_timestamps": []
        }
        save_data()
    else:
        users[uid]["show_in_top"] = True
        if 'takes_timestamps' not in users[uid]:
            users[uid]['takes_timestamps'] = []
        if users[uid]["username"] != username:
            users[uid]["username"] = username
        save_data()

def get_user_balance(user_id: int) -> Union[float, int]:
    return users.get(user_id, {}).get("moons", 0)

def add_moons(user_id: int, amount: int) -> None:
    if user_id in users and users[user_id]["moons"] != float('inf'):
        users[user_id]["moons"] += amount
        save_data()

def transfer_moons(sender_id: int, receiver_id: int, amount: int) -> bool:
    sender = users.get(sender_id)
    receiver = users.get(receiver_id)

    if not sender or not receiver:
        return False
    
    if is_account_frozen(sender_id) or is_account_frozen(receiver_id):
        return False

    if sender["moons"] != float('inf') and sender["moons"] < amount:
        return False

    if sender["moons"] != float('inf'):
        sender["moons"] -= amount
    if receiver["moons"] != float('inf'):
        receiver["moons"] += amount

    save_data()
    return True

def deduct_moons(user_id: int, amount: int) -> bool:
    if user_id not in users:
        return False
    if users[user_id]["moons"] == float('inf'):
        return False
    if users[user_id]["moons"] < amount:
        users[user_id]["moons"] = 0
    else:
        users[user_id]["moons"] -= amount
    save_data()
    return True

def reset_top() -> int:
    hidden_count = 0
    for uid, user_data in users.items():
        if uid != MAIN_ADMIN_ID and user_data.get("show_in_top", True):
            user_data["show_in_top"] = False
            hidden_count += 1
    save_data()
    return hidden_count

def find_user_by_input(input_str: str) -> Optional[int]:
    input_str = input_str.strip().lstrip('@').lower()
    try:
        potential_uid = int(input_str)
        if potential_uid in users:
            return potential_uid
    except ValueError:
        pass
    for uid, data in users.items():
        if data["username"].lower() == input_str or data["name"].lower() == input_str:
            return uid
    return None

