def is_moderator(user_id: int, bot_id: str) -> bool:
    if user_id not in storage.users:
        return False
    user = storage.users[user_id]
    return user.is_moderator.get(bot_id, False) or is_admin(user_id, bot_id)

def find_user_by_input(input_str: str) -> Optional[int]:
    input_str = input_str.strip().lstrip('@').lower()
    try:
        uid = int(input_str)
        if uid in storage.users:
            return uid
    except ValueError:
        pass
    for uid, data in storage.users.items():
        if data.username.lower() == input_str or data.name.lower() == input_str:
            return uid
    return None

# ====================== TAKES ======================
def get_takes_count_24h(user_id: int, bot_id: str) -> int:
    if user_id not in storage.users:
        return 0
    user = storage.users[user_id]
    timestamps = user.takes_timestamps.get(bot_id, [])
    now = datetime.now()
    cutoff = now - timedelta(hours=24)
    valid = [ts for ts in timestamps if datetime.fromisoformat(ts) > cutoff]
    user.takes_timestamps[bot_id] = valid
    return len(valid)

def can_send_take(user_id: int, bot_id: str) -> Tuple[bool, int]:
    bot_config = storage.bots.get(bot_id)
    if not bot_config:
        return False, 0
    count = get_takes_count_24h(user_id, bot_id)
    remaining = bot_config.max_takes_per_day - count
    return remaining > 0, max(0, remaining)

def add_take_timestamp(user_id: int, bot_id: str):
    if user_id not in storage.users:
        return
    user = storage.users[user_id]
    if bot_id not in user.takes_timestamps:
        user.takes_timestamps[bot_id] = []
    user.takes_timestamps[bot_id].append(datetime.now().isoformat())
    storage.save()

# ====================== EXCHANGE RATES ======================
def get_exchange_rate(bot_id: str) -> float:
    if storage.exchange_rates.rates_locked:
        bot_config = storage.bots.get(bot_id)
        return bot_config.base_exchange_rate if bot_config else 0.5
    return storage.exchange_rates.rates.get(bot_id, 0.5)

def convert_currency(user_id: int, from_bot: str, to_bot: str, amount: float) -> Tuple[bool, float, str]:
    if user_id not in storage.users:
        return False, 0, "Пользователь не найден"

    user = storage.users[user_id]
    from_balance = user.balances.get(from_bot, 0)

    if from_balance == float('inf') or from_balance == "inf":
        return False, 0, "Владельцы не могут конвертировать"

    if float(from_balance) < amount:
        return False, 0, "Недостаточно средств"

    from_rate = get_exchange_rate(from_bot)
    to_rate = get_exchange_rate(to_bot)
    converted = amount * from_rate / to_rate

    user.balances[from_bot] = float(from_balance) - amount

    to_balance = user.balances.get(to_bot, 0)
    if to_balance != float('inf') and to_balance != "inf":
        user.balances[to_bot] = float(to_balance) + converted

    storage.save()
    return True, converted, "OK"

def reset_exchange_rates():
    storage.exchange_rates.rates_locked = True
    storage.exchange_rates.rates = {"main": 1.0}
    for bot_id, config in storage.bots.items():
        if bot_id != "main":
            storage.exchange_rates.rates[bot_id] = config.base_exchange_rate
    storage.save()

