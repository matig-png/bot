def get_or_create_user(user: User, bot_id: str) -> UserData:
    """Получить или создать пользователя."""
    uid = user.id
    username = user.username or f"user{uid}"
    name = user.full_name

    if uid not in storage.users:
        storage.users[uid] = UserData(user_id=uid, username=username, name=name)

    user_data = storage.users[uid]
    user_data.username = username
    user_data.name = name

    if bot_id not in user_data.balances:
        bot_config = storage.bots.get(bot_id)
        is_owner_flag = bot_config and bot_config.owner_id == uid
        is_admin_flag = bot_id == "main" and uid in ADMIN_IDS
        is_main_owner = bot_id == "main" and uid == MAIN_ADMIN_ID

        if is_owner_flag or is_main_owner:
            user_data.balances[bot_id] = float('inf')
        elif is_admin_flag:
            user_data.balances[bot_id] = storage.bots[bot_id].admin_starting_balance
        else:
            user_data.balances[bot_id] = 0

        user_data.quiz_passed[bot_id] = False
        user_data.takes_timestamps[bot_id] = []
        user_data.show_in_top[bot_id] = True
        user_data.is_blocked[bot_id] = False
        user_data.is_frozen[bot_id] = False
        user_data.is_moderator[bot_id] = False
        user_data.is_admin[bot_id] = is_admin_flag or is_owner_flag or is_main_owner
        user_data.is_owner[bot_id] = is_owner_flag or is_main_owner

    storage.save()
    return user_data


