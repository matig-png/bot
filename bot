def add_balance(user_id: int, bot_id: str, amount: float) -> bool:
    if user_id not in storage.users:
        return False
    user = storage.users[user_id]
    current = user.balances.get(bot_id, 0)
    if current == float('inf') or current == "inf":
        return True
    user.balances[bot_id] = float(current) + amount
    storage.save()
    return True

def deduct_balance(user_id: int, bot_id: str, amount: float) -> bool:
    if user_id not in storage.users:
        return False
    user = storage.users[user_id]
    current = user.balances.get(bot_id, 0)
    if current == float('inf') or current == "inf":
        return True
    if float(current) < amount:
        return False
    user.balances[bot_id] = float(current) - amount
    storage.save()
    return True

def transfer_balance(sender_id: int, receiver_id: int, bot_id: str, amount: float) -> Tuple[bool, str]:
    if sender_id not in storage.users or receiver_id not in storage.users:
        return False, "Пользователь не найден"

    sender = storage.users[sender_id]
    receiver = storage.users[receiver_id]

    if sender.is_frozen.get(bot_id, False):
        return False, "Ваш счёт заморожен"
    if receiver.is_frozen.get(bot_id, False):
        return False, "Счёт получателя заморожен"

    sender_balance = sender.balances.get(bot_id, 0)
    if sender_balance != float('inf') and sender_balance != "inf":
        if float(sender_balance) < amount:
            return False, "Недостаточно средств"
        sender.balances[bot_id] = float(sender_balance) - amount

    receiver_balance = receiver.balances.get(bot_id, 0)
    if receiver_balance != float('inf') and receiver_balance != "inf":
        receiver.balances[bot_id] = float(receiver_balance) + amount

    storage.save()
    return True, "OK"

def is_admin(user_id: int, bot_id: str) -> bool:
    if user_id not in storage.users:
        return False
    user = storage.users[user_id]
    return user.is_admin.get(bot_id, False) or user.is_owner.get(bot_id, False)

def is_owner(user_id: int, bot_id: str) -> bool:
    if user_id not in storage.users:
