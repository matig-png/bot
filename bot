    async def finalize_bot_setup(message, state, request, main_bot):
        """Завершение настройки и запуск подключённого бота."""
        await message.answer("⏳ Запускаю бота...")

        try:
            new_bot_id = f"bot_{request.user_id}_{int(datetime.now().timestamp())}"

            new_config = BotConfig(
                bot_id=new_bot_id,
                token=request.token,
                currency_name=request.currency_name,
                currency_emoji=request.currency_emoji,
                channel_url=request.channel_url,
                takes_channel=request.takes_channel,
                shop_channel=request.shop_channel,
                modules=request.modules,
                owner_id=request.user_id,
                base_exchange_rate=0.5
            )

            storage.bots[new_bot_id] = new_config

            # Настраиваем владельца
            user = storage.users.get(request.user_id)
            if user:
                user.is_owner[new_bot_id] = True
                user.is_admin[new_bot_id] = True
                user.balances[new_bot_id] = float('inf')
                user.quiz_passed[new_bot_id] = False
                user.takes_timestamps[new_bot_id] = []
                user.show_in_top[new_bot_id] = True
                user.is_blocked[new_bot_id] = False
                user.is_frozen[new_bot_id] = False
                user.is_moderator[new_bot_id] = False

            storage.exchange_rates.rates[new_bot_id] = 0.5

            # Удаляем заявку
            if request.request_id in storage.pending_requests:
                del storage.pending_requests[request.request_id]
            storage.save()

            # Создаём и запускаем бота
            new_bot = Bot(token=request.token)
            new_dp = Dispatcher(storage=MemoryStorage())
            create_bot_handlers(new_bot_id, new_bot, new_dp)

            storage.active_bots[new_bot_id] = new_bot
            storage.active_dispatchers[new_bot_id] = new_dp

            asyncio.create_task(new_dp.start_polling(new_bot))

            modules_text = ", ".join(request.modules)
            await message.answer(
                f"✅ Бот успешно подключён!\n\n"
                f"💰 Валюта: {request.currency_name} {request.currency_emoji}\n"
                f"📦 Модули: {modules_text}\n\n"
                f"Вы — владелец с бесконечным балансом.\n"
                f"Перейдите в бота и нажмите /start",
                reply_markup=build_main_menu("main")
            )

            try:
                await main_bot.send_message(MAIN_ADMIN_ID, f"✅ Бот {new_bot_id} запущен!")
            except Exception:
                pass

        except Exception as e:
            logger.error(f"Ошибка запуска бота: {e}")
            await message.answer(f"❌ Ошибка: {e}", reply_markup=build_main_menu("main"))

        await state.clear()

    dp.include_router(router)


# ====================== ГЛАВНАЯ ФУНКЦИЯ ======================

async def main():
    """Точка входа: загрузка данных, запуск ботов, восстановление задач."""
    storage.load()

    # Главный бот
    main_bot = Bot(token=MAIN_BOT_TOKEN)
    main_dp = Dispatcher(storage=MemoryStorage())

    create_bot_handlers("main", main_bot, main_dp)
    create_connection_handlers(main_bot, main_dp)

    storage.active_bots["main"] = main_bot
    storage.active_dispatchers["main"] = main_dp

    # Запускаем подключённые боты
    for bot_id, config in storage.bots.items():
        if bot_id != "main":
            try:
                connected_bot = Bot(token=config.token)
                connected_dp = Dispatcher(storage=MemoryStorage())
                create_bot_handlers(bot_id, connected_bot, connected_dp)
                storage.active_bots[bot_id] = connected_bot
                storage.active_dispatchers[bot_id] = connected_dp
                asyncio.create_task(connected_dp.start_polling(connected_bot))
                logger.info(f"Запущен бот: {bot_id}")
            except Exception as e:
                logger.error(f"Ошибка запуска {bot_id}: {e}")

    # ===== ВОССТАНОВЛЕНИЕ ЗАДАЧ УДАЛЕНИЯ ПИАРА =====
    now = datetime.now()
    to_remove = []

    for deletion_id, info in storage.scheduled_deletions.items():
        try:
            delete_at = datetime.fromisoformat(info['delete_at'])
            target_bot_id = info['bot_id']
            target_bot = storage.active_bots.get(target_bot_id)

            if not target_bot:
                logger.warning(f"Бот {target_bot_id} не найден для задачи {deletion_id}")
                to_remove.append(deletion_id)
                continue

            if delete_at <= now:
                # Время уже прошло — удаляем сразу
                logger.info(f"Просроченная задача {deletion_id}, удаляем сейчас")
                try:
                    if info.get('is_pinned'):
                        await target_bot.unpin_chat_message(info['channel'], info['message_id'])
                    await target_bot.delete_message(info['channel'], info['message_id'])
                except Exception as e:
                    logger.error(f"Ошибка удаления просроченного: {e}")
                to_remove.append(deletion_id)
            else:
                # Осталось время — планируем
                remaining_seconds = (delete_at - now).total_seconds()
                remaining_hours = remaining_seconds / 3600
                logger.info(f"Восстановлена задача {deletion_id}, осталось {remaining_hours:.1f}ч")

                asyncio.create_task(
                    delayed_delete_message(
                        target_bot, info['channel'],
                        info['message_id'], remaining_hours,
                        info.get('is_pinned', False), deletion_id
                    )
                )
        except Exception as e:
            logger.error(f"Ошибка восстановления задачи {deletion_id}: {e}")
            to_remove.append(deletion_id)

    # Удаляем обработанные записи
    for did in to_remove:
        if did in storage.scheduled_deletions:
            del storage.scheduled_deletions[did]
    if to_remove:
        storage.save()

    active_deletions = len(storage.scheduled_deletions)
    logger.info(f"Активных задач удаления: {active_deletions}")
    # ===== КОНЕЦ ВОССТАНОВЛЕНИЯ =====

    logger.info("Запуск главного бота...")
    await main_dp.start_polling(main_bot)


if __name__ == "__main__":
    print("🚀 Запуск бота...")
    asyncio.run(main())
