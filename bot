@dp.message(TransferStates.WaitingAmountAndMessage)
async def receive_amount_and_message(message: types.Message, state: FSMContext) -> None:
    sender_uid = message.from_user.id
    lines = message.text.strip().split('\n', 1)
    
    try:
        amount = int(lines[0].strip())
        if amount <= 0:
            raise ValueError
    except ValueError:
        await message.answer("Введите корректное положительное число в первой строке.", reply_markup=build_transfer_cancel_keyboard())
        return
    
    transfer_message = lines[1].strip() if len(lines) > 1 else ""

    data = await state.get_data()
    receiver_uid = data.get("receiver_uid")

    if receiver_uid not in users:
        await message.answer("Получатель не найден. Отмена операции.", reply_markup=build_main_menu())
        await state.clear()
        return

    if transfer_moons(sender_uid, receiver_uid, amount):
        await message.answer(
            f"✅ Вы успешно перевели {amount} 🌗 пользователю @{users[receiver_uid]['username']}.",
            reply_markup=build_main_menu()
        )
        
        notification = f"🎉 Вам перевели {amount} 🌗 от @{users[sender_uid]['username']}!"
        if transfer_message:
            notification += f"\n\n💬 Сообщение: {transfer_message}"
        
        try:
            await bot.send_message(receiver_uid, notification)
        except:
            pass
    else:
        if is_account_frozen(sender_uid):
            await message.answer("❄️ Ваш счёт заморожен!", reply_markup=build_main_menu())
        else:
            await message.answer("Недостаточно лун на счёте.", reply_markup=build_main_menu())

    await state.clear()

