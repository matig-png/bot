    @router.message(ConnectBotStates.WaitingTakesChannel)
    async def tc(message: types.Message, state: FSMContext):
        data = await state.get_data()
        req = storage.pending_requests.get(data.get('request_id'))
        if not req:
            return
        ch = message.text.strip()
        if not ch.startswith("@"):
            ch = "@" + ch.replace("https://t.me/", "")
        req.takes_channel = ch
        storage.save()
        if "shop" in req.modules:
            await message.answer("Группа магазина (@gr):")
            await state.set_state(ConnectBotStates.WaitingShopChannel)
        else:
            await finish(message, state, req, bot_instance)

    @router.message(ConnectBotStates.WaitingShopChannel)
    async def sc(message: types.Message, state: FSMContext):
        data = await state.get_data()
        req = storage.pending_requests.get(data.get('request_id'))
        if not req:
            return
        ch = message.text.strip()
        if not ch.startswith("@"):
            ch = "@" + ch.replace("https://t.me/", "")
        req.shop_channel = ch
        storage.save()
        await finish(message, state, req, bot_instance)

    async def finish(message, state, req, main_bot):
        await message.answer("⏳ Запуск...")
        try:
            nid = f"bot_{req.user_id}_{int(datetime.now().timestamp())}"
            ncfg = BotConfig(
                bot_id=nid, token=req.token, currency_name=req.currency_name,
                currency_emoji=req.currency_emoji, channel_url=req.channel_url,
                takes_channel=req.takes_channel, shop_channel=req.shop_channel,
                modules=req.modules, owner_id=req.user_id, base_exchange_rate=0.5,
                take_cooldown_minutes=3
            )
            storage.bots[nid] = ncfg
            user = storage.users.get(req.user_id)
            if user:
                user.is_owner[nid] = True
                user.is_admin[nid] = True
                user.balances[nid] = float('inf')
                user.quiz_passed[nid] = False
                user.takes_timestamps[nid] = []
                user.show_in_top[nid] = True
                user.is_blocked[nid] = False
                user.is_frozen[nid] = False
                user.is_moderator[nid] = False
            storage.exchange_rates.rates[nid] = 0.5
            if req.request_id in storage.pending_requests:
                del storage.pending_requests[req.request_id]
            storage.save()

            nb = Bot(token=req.token)
            nd = Dispatcher(storage=MemoryStorage())
            create_bot_handlers(nid, nb, nd)
            storage.active_bots[nid] = nb
            storage.active_dispatchers[nid] = nd
            asyncio.create_task(nd.start_polling(nb))

            await message.answer(
                f"✅ Подключён!\n💰 {req.currency_name} {req.currency_emoji}\n📦 {', '.join(req.modules)}\n\n/start в боте",
                reply_markup=build_main_menu("main")
            )
            try:
                await main_bot.send_message(MAIN_ADMIN_ID, f"✅ {nid}")
            except Exception:
                pass
        except Exception as e:
            logger.error(f"Запуск: {e}")
            await message.answer(f"❌ {e}", reply_markup=build_main_menu("main"))
        await state.clear()

    dp.include_router(router)


# ====================== MAIN ======================

async def main():
    storage.load()

    main_bot = Bot(token=MAIN_BOT_TOKEN)
    main_dp = Dispatcher(storage=MemoryStorage())
    create_bot_handlers("main", main_bot, main_dp)
    create_connection_handlers(main_bot, main_dp)
    storage.active_bots["main"] = main_bot
    storage.active_dispatchers["main"] = main_dp

    for bot_id, config in storage.bots.items():
        if bot_id != "main":
            try:
                cb = Bot(token=config.token)
                cd = Dispatcher(storage=MemoryStorage())
                create_bot_handlers(bot_id, cb, cd)
                storage.active_bots[bot_id] = cb
                storage.active_dispatchers[bot_id] = cd
                asyncio.create_task(cd.start_polling(cb))
                logger.info(f"Запущен: {bot_id}")
            except Exception as e:
                logger.error(f"Ошибка {bot_id}: {e}")

    # Восстановление задач удаления
    now = datetime.now()
    to_remove = []
    for did, info in storage.scheduled_deletions.items():
        try:
            da = datetime.fromisoformat(info['delete_at'])
            tb = storage.active_bots.get(info['bot_id'])
            if not tb:
                to_remove.append(did)
                continue
            if da <= now:
                logger.info(f"Просрочено: {did}")
                try:
                    if info.get('is_pinned'):
                        await tb.unpin_chat_message(info['channel'], info['message_id'])
                    await tb.delete_message(info['channel'], info['message_id'])
                except Exception as e:
                    logger.error(f"Удаление просроченного: {e}")
                to_remove.append(did)
            else:
                rem = (da - now).total_seconds() / 3600
                logger.info(f"Восстановлено: {did}, {rem:.1f}ч")
                asyncio.create_task(delayed_delete_message(
                    tb, info['channel'], info['message_id'], rem, info.get('is_pinned', False), did
                ))
        except Exception as e:
            logger.error(f"Восстановление {did}: {e}")
            to_remove.append(did)

    for d in to_remove:
        if d in storage.scheduled_deletions:
            del storage.scheduled_deletions[d]
    if to_remove:
        storage.save()

    logger.info(f"Задач удаления: {len(storage.scheduled_deletions)}")
    logger.info("Запуск...")
    await main_dp.start_polling(main_bot)


if __name__ == "__main__":
    print("🚀 Запуск бота...")
    asyncio.run(main())
