# ====================== ПЕРЕСЫЛКА ТЕЙКА В КАНАЛ ======================

async def forward_take_to_channel(message: types.Message, bot_id: str, bot_instance: Bot) -> Optional[types.Message]:
    """Пересылает тейк в канал с цензурой мата."""
    try:
        config = storage.bots.get(bot_id)
        if not config or not config.takes_channel:
            return None

        text = message.text or message.caption or ""
        censored_text, has_profanity = censor_profanity(text, bot_id)

        send_kwargs = {
            "caption": censored_text if has_profanity else text,
            "parse_mode": "HTML" if has_profanity else None
        }

        if message.photo:
            return await bot_instance.send_photo(config.takes_channel, photo=message.photo[-1].file_id, **send_kwargs)
        elif message.video:
            return await bot_instance.send_video(config.takes_channel, video=message.video.file_id, **send_kwargs)
        elif message.animation:
            return await bot_instance.send_animation(config.takes_channel, animation=message.animation.file_id, **send_kwargs)
        elif message.document:
            return await bot_instance.send_document(config.takes_channel, document=message.document.file_id, **send_kwargs)
        elif message.voice:
            return await bot_instance.send_voice(config.takes_channel, voice=message.voice.file_id, **send_kwargs)
        elif message.audio:
            return await bot_instance.send_audio(config.takes_channel, audio=message.audio.file_id, **send_kwargs)
        elif message.sticker:
            return await bot_instance.send_sticker(config.takes_channel, sticker=message.sticker.file_id)
        else:
            return await bot_instance.send_message(
                config.takes_channel,
                censored_text if has_profanity else text,
                parse_mode="HTML" if has_profanity else None
            )
    except Exception as e:
        logger.error(f"Ошибка пересылки тейка: {e}")
        return None


# ====================== ОТЛОЖЕННОЕ УДАЛЕНИЕ ПИАРА ======================

async def delayed_delete_message(bot_instance: Bot, channel: str, message_id: int,
                                  hours: float, is_pinned: bool, deletion_id: str):
    """Удаляет сообщение через указанное время. Данные удаляются после выполнения."""
    try:
        await asyncio.sleep(hours * 3600)

        # Открепляем если было закреплено
        if is_pinned:
            try:
                await bot_instance.unpin_chat_message(channel, message_id)
                logger.info(f"Откреплено сообщение {message_id} из {channel}")
            except Exception as e:
                logger.error(f"Ошибка открепления: {e}")

        # Удаляем сообщение
        try:
            await bot_instance.delete_message(channel, message_id)
            logger.info(f"Удалено сообщение пиара {message_id} из {channel}")
        except Exception as e:
            logger.error(f"Ошибка удаления: {e}")

        # Удаляем данные о задаче
        if deletion_id in storage.scheduled_deletions:
            del storage.scheduled_deletions[deletion_id]
            storage.save()
            logger.info(f"Данные задачи {deletion_id} удалены")

    except asyncio.CancelledError:
        logger.info(f"Задача удаления {deletion_id} отменена")
    except Exception as e:
        logger.error(f"Ошибка отложенного удаления: {e}")


