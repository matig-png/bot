    if message.from_user.id != MAIN_ADMIN_ID:
        await state.clear()
        return

    try:
        amount = int(message.text.strip())
        if amount <= 0:
            raise ValueError
    except ValueError:
        await message.answer("Введите корректное положительное число.", reply_markup=build_cancel_keyboard())
        return

    data = await state.get_data()
    target_uid = data.get("target_uid")

    if deduct_moons(target_uid, amount):
        await message.answer(
            f"✅ Списано {amount} 🌗. Новый баланс: {users[target_uid]['moons']} 🌗",
