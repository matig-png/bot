        async def process_take_message(message: types.Message, bid: str, bot: Bot):
            uid = message.from_user.id
            if uid not in storage.users:
                get_or_create_user(message.from_user, bid)
            user = storage.users.get(uid)
            cfg = storage.bots.get(bid)

            if user and user.is_blocked.get(bid, False):
                await message.answer("🚫 Вы заблокированы для тейков.")
                return False

            can_take, cooldown_msg = can_send_take(uid, bid)
            if not can_take:
                await message.answer(f"⏳ {cooldown_msg}")
                return False

            text = message.text or message.caption or ""

            # Проверка маркеров
            needs_mod = contains_marker_words(text, bid)
            mod_reason = "Маркерное слово"

            # Проверка ссылок на группы
            if not needs_mod:
                has_group, link_reason = await check_telegram_links(text, bot)
                if has_group:
                    needs_mod = True
                    mod_reason = link_reason

            if needs_mod:
                take_id = str(uuid.uuid4())[:8]
                storage.pending_takes[take_id] = {
                    'user_id': uid, 'bot_id': bid, 'text': text,
                    'photo': message.photo[-1].file_id if message.photo else None,
                    'video': message.video.file_id if message.video else None,
                    'animation': message.animation.file_id if message.animation else None,
                    'document': message.document.file_id if message.document else None,
                    'voice': message.voice.file_id if message.voice else None,
                    'audio': message.audio.file_id if message.audio else None,
                    'sticker': message.sticker.file_id if message.sticker else None,
                    'caption': message.caption
                }
                storage.save()

                # Модераторам БЕЗ username (анонимно)
                for mod_uid, mod_user in storage.users.items():
                    if is_moderator(mod_uid, bid):
                        try:
                            blocked = storage.users[uid].is_blocked.get(bid, False)
                            await bot.send_message(
                                mod_uid,
                                f"⚠️ Тейк на модерации\nПричина: {mod_reason}\n\n{text}",
                                reply_markup=build_take_moderation_keyboard(take_id, uid, blocked)
                            )
                            await message.copy_to(mod_uid)  # copy_to вместо forward — без автора
                        except Exception as e:
                            logger.error(f"Ошибка модератору {mod_uid}: {e}")

                await message.answer("📝 Тейк на модерации.", reply_markup=build_main_menu(bid))
                return True
            else:
                sent = await forward_take_to_channel(message, bid, bot)
                if sent:
                    add_take_timestamp(uid, bid)
                    await message.answer("✅ Тейк отправлен!", reply_markup=build_main_menu(bid))
                    return True
                else:
                    await message.answer("❌ Ошибка.", reply_markup=build_main_menu(bid))
                    return False

